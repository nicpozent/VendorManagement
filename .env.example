# Copy to .env and fill in to go live with Entra + Microsoft Graph.
# Leave everything blank to run in dev-auth + mock-Graph mode (no tenant needed).

# Postgres
POSTGRES_PASSWORD=devpassword

# ---- Backend API app registration (confidential client, app-only Graph) ----
AZURE_TENANT_ID=
AZURE_API_CLIENT_ID=
AZURE_API_CLIENT_SECRET=
# Audience the API validates (api://<api-client-id> or the client id)
AZURE_API_AUDIENCE=
# Mailbox (UPN or object id) that reminders & NDA emails are sent "From" via Graph
GRAPH_SENDER_USER_ID=

# ---- Frontend SPA app registration (public client / PKCE) ----
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=
# Scope the SPA requests for the API access token, e.g. api://<api-client-id>/access_as_user
VITE_API_SCOPE=
